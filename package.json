{
  "name": "personal-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "My personal website",
  "author": "Bruno Pulis",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunopulis/personal-site.git"
  },
  "scripts": {
    "audit:ci": "npm audit --audit-level=high",
    "clean": "rimraf _site",
    "clean:og": "rimraf src/assets/og-images",
    "dev": "run-p dev:*",
    "dev:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --watch",
    "dev:11ty": "eleventy --serve --port=8080 --incremental",
    "dev:search": "npx pagefind --site _site --serve",
    "build": "run-p build:css build:setup && cross-env ELEVENTY_ENV=production eleventy && npx pagefind --site _site",
    "build:search": "npx pagefind --site _site",
    "build:setup": "node scripts/build-setup.js",
    "build:screenshots": "node src/_config/setup/generate-screenshots.js",
    "add-movie": "node scripts/add-movie.js",
    "sync-movies": "node scripts/sync-movies.js",
    "sync-shows": "node scripts/sync-shows.js",
    "sync-from-list": "node scripts/sync-from-list.js",
    "build:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "pa11y-ci",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:ci": "start-server-and-test 'eleventy --serve --port=8080' http://localhost:8080 'cypress run'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,json,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-fetch": "^5.1.3",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/is-land": "^5.0.1",
    "lite-youtube-embed": "^0.3.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@toycode/markdown-it-class": "^1.2.4",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.2",
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.2",
    "cypress": "^15.18.1",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "html-minifier-terser": "^7.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "liquidjs": "10.27.2",
    "luxon": "^3.7.2",
    "markdown-it": "^14.3.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.1",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-prism": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.16",
    "prettier-plugin-jinja-template": "^2.2.0",
    "rimraf": "^6.1.3",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.3",
    "sharp-ico": "^0.1.5",
    "slugify": "^1.6.9",
    "start-server-and-test": "^3.0.11",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.2",
    "vitest": "^4.1.8"
  }
}
