{
  "name": "personal-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "description": "My personal website",
  "author": "Bruno Pulis",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunopulis/personal-site.git"
  },
  "scripts": {
    "clean": "rimraf _site",
    "clean:og": "rimraf src/assets/og-images",
    "dev": "run-p dev:*",
    "dev:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --watch",
    "dev:11ty": "eleventy --serve --port=8080",
    "build": "run-p build:stats build:css 'build:parallel' && cross-env ELEVENTY_ENV=production eleventy",
    "build:parallel": "run-p build:icons build:highlight build:assets",
    "build:stats": "node scripts/generate-stats.js",
    "build:icons": "node scripts/generate-icons.js",
    "build:assets": "node scripts/fetch-assets.js",
    "build:highlight": "node scripts/fetch-highlight.js",
    "build:screenshots": "node src/_config/setup/generate-screenshots.js",
    "add-movie": "node scripts/add-movie.js",
    "sync-movies": "node scripts/sync-movies.js",
    "sync-shows": "node scripts/sync-shows.js",
    "sync-from-list": "node scripts/sync-from-list.js",
    "build:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "pa11y-ci"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-fetch": "^5.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@11ty/is-land": "^5.0.1",
    "lite-youtube-embed": "^0.3.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@toycode/markdown-it-class": "^1.2.4",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.2",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "html-minifier-terser": "^7.2.0",
    "luxon": "^3.7.2",
    "markdown-it": "^14.2.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-prism": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "pa11y-ci": "^4.1.1",
    "postcss": "^8.5.15",
    "prettier-plugin-jinja-template": "^2.2.0",
    "rimraf": "^6.1.3",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.1",
    "sharp-ico": "^0.1.5",
    "slugify": "^1.6.9",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "vitest": "^4.1.8"
  }
}
