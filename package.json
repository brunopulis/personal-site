{
  "name": "personal-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "description": "My personal website",
  "author": "Bruno Pulis",
  "repository": {
    "type": "git",
    "url": "https://github.com/brunopulis/personal-site.git"
  },
  "scripts": {
    "clean": "rimraf _site",
    "clean:og": "rimraf src/assets/og-images",
    "dev": "run-p dev:*",
    "dev:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --watch",
    "dev:11ty": "eleventy --serve --port=8080",
    "build": "npm run build:stats && npm run build:icons && npm run build:assets && npm run build:css && cross-env ELEVENTY_ENV=production eleventy",
    "build:stats": "node scripts/generate-stats.js",
    "build:icons": "node scripts/generate-icons.js",
    "build:assets": "node scripts/fetch-assets.js",
    "build:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --minify"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-fetch": "^5.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@11ty/is-land": "^5.0.1",
    "lite-youtube-embed": "^0.3.4",
    "markdown-it-table-of-contents": "^1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@toycode/markdown-it-class": "^1.2.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "cssnano": "^7.1.4",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.1",
    "flexsearch": "^0.8.212",
    "html-minifier-terser": "^7.2.0",
    "luxon": "^3.5.0",
    "markdown-it": "^14.1.1",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-prism": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "pa11y-ci": "^4.1.0",
    "postcss": "^8.4.47",
    "prettier-plugin-jinja-template": "^2.1.0",
    "rimraf": "^6.1.3",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.3",
    "sharp-ico": "^0.1.5",
    "slugify": "^1.6.9",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.19"
  }
}
