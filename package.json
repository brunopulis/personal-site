{
  "name": "personal-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "My personal website",
  "author": "Bruno Pulis",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --watch",
    "dev:11ty": "eleventy --serve --port=8080",
    "build": "npm run build:icons && npm run build:assets && npm run build:css && eleventy",
    "build:icons": "node scripts/generate-icons.js",
    "build:assets": "node scripts/fetch-assets.js",
    "build:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/build.css --minify",
    "clean": "rimraf _site",
    "test": "npm run test:build && npm run test:e2e",
    "test:build": "node tests/build-test.js",
    "test:e2e": "playwright test",
    "test:install": "npx playwright install"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "dayjs": "^1.11.20",
    "flexsearch": "^0.8.212",
    "luxon": "^3.5.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.47",
    "prettier": "^3.8.1",
    "prettier-plugin-jinja-template": "^2.1.0",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.3",
    "slugify": "^1.6.9",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "dotenv": "^17.4.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0"
  }
}
