---
import { Image } from 'astro:assets';

import me from '@assets/images/me.webp';
---

<section>
  <div class="wrapper">
    <h2 class="mb-4 text-4xl font-bold">
      Vamos tomar um café? <span aria-hidden="true">☕</span>
    </h2>

    <p class="mx-auto mb-8 max-w-2xl text-xl text-white">
      Se você quer tornar seu produto mais acessível, vamos conversar sem
      compromisso.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="https://cal.com/brunopulis/consultoria-gratuita"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center text-lg font-semibold text-white transition underline underline-offset-8 hover:no-underline"
      >
        Agendar conversa
      </a>
      <a
        href="/servicos"
        class="flex items-center text-lg font-semibold text-white transition underline underline-offset-8 hover:no-underline"
      >
        Ver meus serviços
      </a>
    </div>
  </div>
</section>
