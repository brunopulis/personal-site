---
import { Image } from 'astro:assets';
import cotemig from '@assets/clients/cotemig.svg';
import elleven from '@assets/clients/elleven.svg';
import estacio from '@assets/clients/estacio.svg';
import laraBrenner from '@assets/clients/lara-brenner.svg';
import mariaInclusiva from '@assets/clients/maria-inclusiva.svg';
import reponto from '@assets/clients/reponto.svg';
import una from '@assets/clients/una.svg';
import uniBh from '@assets/clients/uni-bh.svg';
---

<section class="bg-gray-100 py-12">
  <div class="wrapper">
    <h2 class="title">Meus clientes</h2>
    <p class="text-errie-black-900 mb-6 text-4xl font-bold lg:text-5xl">
      Confiam em nosso trabalho
    </p>

    <ul class="grid">
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={laraBrenner}
          alt="Lara Brenner"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={reponto}
          alt="Reponto"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={mariaInclusiva}
          alt="Maria Inclusiva"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={elleven}
          alt="Elleven"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={una}
          alt="Una"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={uniBh}
          alt="Uni BH"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={estacio}
          alt="Estacio de Sa"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
      <li class="flex items-center justify-center p-4 sm:p-8 lg:p-8">
        <Image
          class="max-h-12 w-full object-contain"
          src={cotemig}
          alt="Cotemig"
          loading="lazy"
          decoding="async"
          fetchpriority="high"
          width={230}
          height={48}
        />
      </li>
    </ul>
  </div>
</section>
