---
layout: base.njk
title: Poesias
pagination:
  data: collections.poetry
  size: 10
  alias: items
  reverse: true
permalink: "/poetry/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}"
---

<h1 class="mb-4 font-bold text-2xl">Poetry</h1>
<p class="mb-6 text-gray-600 dark:text-gray-400">Collected poems with their own pages.</p>

{% set items = items | default([]) %}
{% if items | length == 0 %}
  <p class="text-gray-500 dark:text-gray-400 italic">No poems yet. Add files under <code>src/poetry/</code>.</p>
{% else %}
<section class="space-y-6">
  {% for item in items %}
  <article class="pb-4 border-b">
    <h2 class="font-semibold text-lg"><a href="{{ item.url }}">{{ item.data.title or 'Untitled' }}</a></h2>
    {% if item.date %}
      <time class="text-gray-500 text-xs" datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate }}</time>
    {% endif %}
  </article>
  {% endfor %}
</section>
<nav class="flex justify-between items-center mt-8" aria-label="Pagination">
  {% if pagination.href.previous %}
    <a class="bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 px-4 py-2 rounded" href="{{ pagination.href.previous }}">← Newer</a>
  {% else %}
    <span class="px-4 py-2 text-gray-400">← Newer</span>
  {% endif %}

  <span class="text-gray-600 dark:text-gray-400 text-sm">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages | length }}</span>

  {% if pagination.href.next %}
    <a class="bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 px-4 py-2 rounded" href="{{ pagination.href.next }}">Older →</a>
  {% else %}
    <span class="px-4 py-2 text-gray-400">Older →</span>
  {% endif %}
</nav>
{% endif %}
