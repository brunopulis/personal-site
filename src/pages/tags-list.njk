---
layout: base
title: Tags
description: Todas as tags do blog
permalink: /tags/
eleventyComputed:
  title: Tags
---

<h1 class="mb-6 font-bold text-2xl">Tags</h1>

{% if collections.tagsWithCount and collections.tagsWithCount.length %}
<ul class="gap-3 grid grid-cols-1 sm:grid-cols-2">
  {% for t in collections.tagsWithCount %}
    <li class="flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-800 p-3 border rounded">
      <a class="font-medium hover:text-blue-600" href="/tags/{{ t.slug }}/">#{{ t.tag }}</a>
      <span class="text-gray-500 text-xs">{{ t.count }} post{{ 's' if t.count != 1 }}</span>
    </li>
  {% endfor %}
</ul>
{% else %}
  <p class="text-gray-500">Nenhuma tag encontrada.</p>
{% endif %}
