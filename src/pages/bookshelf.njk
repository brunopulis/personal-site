---
layout: base.njk
title: Estante de Livros
permalink: /bookshelf/
---

<section class="mb-8">
  <h1 class="mb-2 font-bold text-3xl">Estante de Livros</h1>
  <p class="text-[var(--text-secondary)]">
    Livros que li, organizados por ano de leitura.
  </p>
</section>

{% set booksGrouped = collections.books | booksByYear %}
{% for year in booksGrouped.years %}
  {% set yearBooks = booksGrouped.byYear[year] %}
  {% set bookCount = yearBooks | length %}

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-6">
      <h2 class="font-bold text-2xl">{{ year }}</h2>
      <span class="bg-[var(--surface)] px-3 py-1 border rounded-full text-[var(--text-secondary)] text-sm">
        {{ bookCount }} {{ "livro" if bookCount == 1 else "livros" }}
      </span>
    </div>

    <div class="gap-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
      {% for book in yearBooks | reverse %}
        {% set hasReview = book.content | striptags | trim | length > 0 %}
        <article class="bg-[var(--surface)] hover:shadow-lg border rounded-lg overflow-hidden transition-shadow">
          <div class="gap-4 p-4">
            {% if book.data.cover %}
              <div class="flex-shrink-0">
                <img
                  src="{{ book.data.cover }}"
                  alt="{{ book.data.title }}"
                  class="rounded w-20 h-30 object-cover"
                  loading="lazy"
                >
              </div>
            {% else %}
              <div class="flex flex-shrink-0 justify-center items-center bg-gradient-to-br from-purple-500 to-pink-500 rounded w-20 h-30">
                <span class="font-bold text-white text-2xl">{{ book.data.title | truncate(1, true, "") }}</span>
              </div>
            {% endif %}

            <div class="my-4">
              <h3 class="mb-1 font-semibold text-lg line-clamp-2 leading-tight">
                {{ book.data.title }}
              </h3>

              {% if book.data.author %}
                <p class="mb-2 text-[var(--text-secondary)] text-sm">
                  {{ book.data.author }}
                </p>
              {% endif %}

              {% if book.data.rating %}
                <div class="flex items-center gap-1 mb-2" aria-label="Nota: {{ book.data.rating }} de 5">
                  {% for i in range(1, 6) %}
                    {% if i <= book.data.rating %}
                      <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    {% else %}
                      <svg class="w-4 h-4 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              {% if hasReview %}
                <a
                  href="{{ book.url }}"
                  class="inline-flex items-center gap-1 text-purple-600 dark:text-purple-400 text-sm hover:underline"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  Ver resenha
                </a>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </section>
{% else %}
  <p class="py-12 text-[var(--text-secondary)] text-center">
    Nenhum livro registrado ainda.
  </p>
{% endfor %}
