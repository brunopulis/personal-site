---
layout: base.njk
title: Estante de Livros
permalink: /bookshelf/
---

<section class="mb-8">
  <h1 class="mb-2 font-bold text-blood-red-950 text-3xl">
    {{ title }}
  </h1>
  <p>Livros que li, organizados por ano de leitura.</p>
</section>

{% set booksGrouped = collections.books | booksByYear %}
{% for year in booksGrouped.years %}
  {% set yearBooks = booksGrouped.byYear[year] %}
  {% set bookCount = yearBooks | length %}

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-6">
      <h2 class="font-bold text-blood-red-950 text-2xl">{{ year }}</h2>
      <span class="bg-vista-blue-500 p-category px-2 py-1 rounded font-bold text-errie-black-950 text-xs transition-colors">
        {{ bookCount }} {{ "livro" if bookCount == 1 else "livros" }}
      </span>
    </div>

    <div class="gap-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
      {% for book in yearBooks | reverse %}
        {% set hasReview = book.content | striptags | trim | length > 0 %}
        <article class="gap-6">
          <div class="py-4">
            {% if book.data.poster %}
              <div class="shrink-0">
                <img
                  src="{{ book.data.poster }}"
                  alt="{{ book.data.title }}"
                  class="w-32 h-58 object-fit-cover"
                  loading="lazy"
                >
              </div>
            {% else %}
              <div class="flex justify-center items-center bg-linear-to-br from-light-silver-500 to-light-silver-500 rounded w-32 h-58 shrink-0">
                <span class="font-bold text-white text-2xl">{{ book.data.title | truncate(1, true, "") }}</span>
              </div>
            {% endif %}

            <div class="my-4">
              <h3 class="mb-1 font-semibold text-lg line-clamp-2 leading-tight">
                {{ book.data.title }}
              </h3>

              {% if book.data.subtitle %}
                <p class="mb-1 text-sm">
                  {{ book.data.subtitle }}
                </p>
              {% endif %}
            </div>

            {% if book.data.author %}
              <p class="mb-2 text-sm">
                {{ book.data.author }}
              </p>
            {% endif %}

            {% if book.data.rating %}
              <div class="flex items-center gap-1 mb-2" aria-label="Nota: {{ book.data.rating }} de 5">
                {% for ratingCount in range(1, 6) %}
                  {% if ratingCount <= book.data.rating %}
                    <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  {% else %}
                    <svg class="w-4 h-4 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}

            {% if hasReview %}
              <a href="{{ book.url }}" class="inline-flex items-center gap-1 text-sm underline hover:no-underline">
                Leia a minha resenha
              </a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </section>
{% else %}
  <p class="py-12 text-[var(--text-secondary)] text-center">
    Nenhum livro registrado ainda.
  </p>
{% endfor %}
