---
layout: base.njk
title: Seriados
permalink: /shows/
---

<section class="mb-8">
  <h1 class="mb-2 font-bold text-3xl">Seriados</h1>
  <p class="text-[var(--text-secondary)]">
    Meus seriados favoritos.
  </p>
</section>

{% set showGrouped = collections.shows | showsByYear %}
{% for year in showGrouped.years %}
  {% set yearShows = showGrouped.byYear[year] %}
  {% set showCount = yearShows | length %}

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-6">
      <h2 class="font-bold text-2xl">{{ year }}</h2>
      <span class="bg-[var(--surface)] px-3 py-1 border rounded-full text-[var(--text-secondary)] text-sm">
        {{ showCount }} {{ "série" if movieCount == 1 else "seriados" }}
      </span>
    </div>

    <div class="gap-3 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
      {% for show in yearShows | reverse %}
        <article>
          <div class="gap-4 py-4">
            {% if show.data.poster %}
              <div class="flex-shrink-0">
                <img
                  src="{{ show.data.poster }}"
                  alt="{{ show.data.title }}"
                  class="rounded w-32 h-48 object-cover"
                  loading="lazy"
                >
              </div>
            {% else %}
              <div class="flex flex-shrink-0 justify-center items-center bg-gradient-to-br from-purple-500 to-pink-500 rounded w-20 h-30">
                <span class="font-bold text-white text-2xl">{{ show.data.title | truncate(1, true, "") }}</span>
              </div>
            {% endif %}

            <div class="my-4">
              <h3 class="mb-1 font-semibold text-lg line-clamp-2 leading-tight">
                {{ show.data.title }}
              </h3>

              {% if show.data.director %}
                <p class="mb-2 text-[var(--text-secondary)] text-sm">
                  {{ show.data.director }}
                </p>
              {% endif %}

              {% if show.data.rating %}
                <div class="flex items-center gap-1 mb-2" aria-label="Nota: {{ show.data.rating }} de 5">
                  {% for i in range(1, 6) %}
                    {% if i <= show.data.rating %}
                      <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    {% else %}
                      <svg class="w-4 h-4 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              {% if show.data.url %}
                <a
                  href="{{ show.data.url }}"
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1 text-purple-600 dark:text-purple-400 text-sm hover:underline"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  Ver no TMDB
                </a>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </section>
{% else %}
  <p class="py-12 text-[var(--text-secondary)] text-center">
    Nenhum seriado registrado ainda.
  </p>
{% endfor %}
