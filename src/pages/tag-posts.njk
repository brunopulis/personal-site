---
layout: base
title: "Tag: {{ tag.tag }}"
description: "Posts com a tag {{ tag.tag }}"
pagination:
  data: collections.tagList
  size: 10
  alias: tag
permalink: "/tags/{{ tag.slug }}/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}{% else %}index{% endif %}.html"
eleventyComputed:
  title: "Tag: {{ tag.tag }}"
eleventyExcludeFromCollections: true
---

{% set posts = collections.posts | getPostsByTag(tag.tag) %}

<section class="wrapper region">
  <header class="flow">
    <h1>Tag: {{ tag.tag }}</h1>
    <p>{{ posts.length }} post{{ 's' if posts.length != 1 else '' }}</p>
    <nav aria-label="Navegação por tags">
      <ul class="cluster" role="list">
        {% for t in collections.tagList %}
        <li><a href="/tags/{{ t.slug }}/" {% if t.tag == tag.tag %}aria-current="page"{% endif %}>#{{ t.tag }}</a></li>
        {% endfor %}
      </ul>
    </nav>
  </header>

  <div class="h-feed flow region" style="--flow-space: var(--space-xl)">
    {% for post in posts %}
    <article class="flow h-entry">
      <header class="flow">
        <h2 class="p-name">
          <a class="u-url" href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>
        <time class="text-step--1 dt-published" datetime="{{ post.data.pubDate | toISOString }}">
          {{ post.data.pubDate | readableDate }}
        </time>
      </header>

      <div class="prose">
        <p class="p-summary">
          {{ post.data.description or (post.templateContent | striptags | truncate(200)) }}
        </p>
      </div>

      <div class="tags-list | cluster" role="list">
        {% for t in post.data.tags %}
        <a class="p-category" href="/tags/{{ t | slug }}/">#{{ t }}</a>
        {% endfor %}
      </div>

      {% if not loop.last %}<hr class="post-separator">{% endif %}
    </article>
    {% endfor %}
  </div>
</section>
