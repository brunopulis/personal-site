---
layout: base.njk
title: "Filmes e Séries"
permalink: /watching/
---

<section class="mb-8">
  <h1 class="mb-2 font-bold text-blood-red-950 text-2xl">Filmes e Séries</h1>
  <p class="mb-4">
    Filmes e séries que assisti, apresentados de forma organizada.
  </p>

  {% set allMovies = collections.movies %}
  {% set allShows = collections.shows %}
  {% set allItems = allMovies | concat(allShows) %}
  {% set yearsGrouped = allItems | groupByYear %}
  {% set years = yearsGrouped.years %}
  {% set currentYear = years[0] %}

  {% if years.length > 0 %}
  <div class="flex items-center content-between gap-2">
    {% for year in years %}
      <a
        href="/watching/{{ year }}/"
        class="px-3 py-1 text-sm rounded-full border transition-colors {% if year == currentYear %}bg-vista-blue-600 font-bold text-white border-vista-blue-600{% else %}bg-vista-blue-100 font-bold text-errie-black-950 border-vista-blue-100 hover:border-vista-blue-500 hover:text-errie-black-950{% endif %}"
      >
        {{ year }}
      </a>
    {% endfor %}
  </div>
  {% endif %}
</section>

{% set recentMovies = collections.movies | sortByDate | limit(8) %}
{% set recentShows = collections.shows | sortByDate | limit(8) %}
{% set favoriteMovies = collections.movies | filterFavorites | sortByDate | limit(8) %}
{% set favoriteShows = collections.shows | filterFavorites | sortByDate | limit(8) %}

{% if recentMovies.length > 0 %}
<section class="mb-12" aria-labelledby="recent-movies">
  <div class="flex items-center gap-3 mb-6">
    <h2 class="font-bold text-blood-red-950 text-2xl" id="recent-movies">
      <span aria-hidden="true">🍿</span> Filmes Recentes
    </h2>
    <a href="/watching/movies/" class="text-vista-blue-600 dark:text-vista-blue-400 text-sm hover:underline">Ver todos →</a>
  </div>

  {% if recentMovies.length > 0 %}
  <div class="gap-3 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 h-feed">
    {% for movie in recentMovies %}
      <article class="mb-5 h-entry">
        <a href="{{ movie.url }}" class="block">
          {% if movie.data.poster %}
            <img
              src="{{ movie.data.poster | localPoster }}"
              alt="{{ movie.data.title }}"
              class="rounded w-full object-cover aspect-2/3"
              loading="lazy"
            >
          {% else %}
            <div class="flex justify-center items-center bg-linear-to-br from-vista-blue-500 to-blood-red-500 rounded w-full aspect-2/3">
              <span class="font-bold text-white text-2xl">
                {{ movie.data.title | truncate(1, true, "") }}
              </span>
            </div>
          {% endif %}
          <p>{{ movie.data.director }}</p>
          <div class="mt-2">
            <h3 class="font-semibold text-sm line-clamp-2 leading-tight">
              {{ movie.data.title }}
            </h3>
            {% if movie.data.rating %}
              <p class="flex items-center gap-1 text-yellow-500 text-xs">
                {% for i in range(1, 6) %}
                  {% if i <= movie.data.rating %}⭐{% endif %}
                {% endfor %}
              </p>
            {% endif %}
          </div>
        </a>
      </article>
    {% endfor %}
  </div>
  {% else %}
    <p>Nenhum filme registrado ainda.</p>
  {% endif %}
</section>
{% endif %}

