---
import Layout from "@layout/Layout.astro";

import Header from "@components/layouts/Header.astro";
import HeroSection from "@components/layouts/HeroSection.astro";
import Footer from "@components/layouts/Footer.astro";
---

<Layout title="O que estou fazendo agora - Bruno Pulis">
  <Header />
  <main id="main-content">
    <HeroSection title="Agora" description="Última atualização: Junho 22, 2025" />

    <section>
      <div class="container mx-auto">
        <div class="prose mx-auto max-w-4xl">
          <p class="lead">
            Essa página foi inspirado no trabalho de <a href="sive.rs" rel="noopener noreferrer" target="_blank">Derek Sivers</a> que você pode conferir em <a
              href="https://nownownow.com">nownownow</a
            >. O objetivo é mostrar no que estou focado no momento.
          </p>
          <p>Esse site passou por atualizações recentes e é um trabalho em andamento.</p>

          <h2>No trabalho</h2>
          <p>

          </p>

          <h2>O que não estou fazendo</h2>
          <ul>
            <li>Redes sociais (pausa intencional);</li>
            <li>Séries (escolhi ler mais);</li>
            <li>Projetos de remediação (focando em auditoria e mentoria).</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
