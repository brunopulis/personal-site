---
layout: base.njk
pagination:
  data: collections.watchingYears
  size: 1
  alias: year
permalink: /watching/{{ year }}/
generate: true
---

<section class="mb-8">
  <nav class="mb-4 text-sm">
    <a href="/watching/" class="text-vistaBlue-600 dark:text-vistaBlue-400 hover:underline">Watching</a>
    <span class="mx-2">→</span>
    <span>{{ year }}</span>
  </nav>

  {% set allMovies = collections.movies %}
  {% set allShows = collections.shows %}
  {% set allItems = allMovies | concat(allShows) %}
  {% set yearsGrouped = allItems | groupByYear %}
  {% set years = yearsGrouped.years %}
  {% set currentYear = year %}

  <div class="flex items-center content-between gap-2 mb-6">
    {% for year in years %}
      <a
        href="/watching/{{ y }}/"
        class="px-3 py-1 text-sm rounded-full border transition-colors {% if y == currentYear %}bg-vistaBlue-600 font-bold text-white border-vistaBlue-600{% else %}bg-vistaBlue-100 font-bold text-errieBlack-950 border-vistaBlue-100 hover:border-vistaBlue-500 hover:text-errieBlack-950{% endif %}"
      >
        {{ year }}
      </a>
    {% endfor %}
  </div>

  <h1 class="mb-2 font-bold text-3xl">{{ year }}</h1>
  <p class="mb-4 text-errieBlack-900">
    Filmes e séries assistidos em {{ year }}.
  </p>
</section>

{% set yearMovies = collections.movies | filterByYear(year) %}
{% set yearShows = collections.shows | filterByYear(year) %}
{% set recentMovies = yearMovies | reverse | limit(6) %}
{% set recentShows = yearShows | reverse | limit(6) %}
{% set favoriteMovies = yearMovies | filterFavorites | reverse | limit(6) %}
{% set favoriteShows = yearShows | filterFavorites | reverse | limit(6) %}

{% if recentMovies.length > 0 %}
<section class="mb-12" aria-labelledby="recent-movies">
  <div class="flex items-center gap-3 mb-6">
    <h2 class="font-bold text-blood-red-950 text-2xl" id="recent-movies">
      <span aria-hidden="true">🍿</span> Filmes Recentes
    </h2>
    <a href="/watching/movies/" class="text-vista-blue-500 text-sm underline hover:no-underline">
      Ver todos <span class="sr-only">os filmes recentes</span>
    </a>
  </div>

  <div class="gap-3 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
    {% for movie in recentMovies %}
      <article>
        <a href="{{ movie.url }}" class="block">
          {% if movie.data.poster %}
            <img
              src="{{ movie.data.poster }}"
              alt="{{ movie.data.title }}"
              class="rounded w-full object-cover aspect-2/3"
              loading="lazy"
            >
          {% else %}
            <div class="flex justify-center items-center rounded w-full aspect-2/3">
              <span class="font-bold text-white text-2xl">{{ movie.data.title | truncate(1, true, "") }}</span>
            </div>
          {% endif %}
          <div class="mt-2">
            <h3 class="font-bold text-blood-red-950 text-sm line-clamp-2 leading-tight">
              {{ movie.data.title }}
            </h3>
            <p class="py-2">{{ movie.data.director }}</p>
            {% if movie.data.rating %}
              <p class="flex items-center gap-1 text-yellow-500 text-xs">
                {% for i in range(1, 6) %}
                  {% if i <= movie.data.rating %}⭐{% endif %}
                {% endfor %}
              </p>
            {% endif %}
          </div>
        </a>
      </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if recentShows.length > 0 %}
<section class="mb-12" aria-labelledby="recent-shows">
