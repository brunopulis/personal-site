---
layout: base.njk
title: Filmes
permalink: /watching/movies/
---

<section class="mb-8">
  <nav class="mb-4 text-sm">
    <a href="/watching/" class="text-vistaBlue-600 dark:text-vistaBlue-400 hover:underline">Filmes e Séries</a>
    <span class="mx-2">→</span>
    <span>Filmes</span>
  </nav>
  <h1 class="mb-2 font-bold text-3xl">Filmes</h1>
  <p class="text-[var(--text-secondary)]">
    Todos os filmes que assisti.
  </p>
</section>

{% set moviesGrouped = collections.movies | moviesByYear %}

{% for year in moviesGrouped.years %}
  {% set yearMovies = moviesGrouped.byYear[year] %}
  {% set movieCount = yearMovies | length %}

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-6">
      <h2 class="font-bold text-2xl">{{ year }}</h2>
      <span class="bg-[var(--surface)] px-3 py-1 border rounded-full text-[var(--text-secondary)] text-sm">
        {{ movieCount }} {{ "filme" if movieCount == 1 else "filmes" }}
      </span>
    </div>

    <div class="gap-3 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {% for movie in yearMovies | reverse %}
        <article>
          <a href="{{ movie.url }}" class="block">
            {% if movie.data.poster %}
              <img
                src="{{ movie.data.poster }}"
                alt="{{ movie.data.title }}"
                class="rounded w-full object-cover aspect-[2/3]"
                loading="lazy"
              >
            {% else %}
              <div class="flex justify-center items-center bg-gradient-to-br from-vistaBlue-500 to-bloodRed-500 rounded w-full aspect-[2/3]">
                <span class="font-bold text-white text-2xl">{{ movie.data.title | truncate(1, true, "") }}</span>
              </div>
            {% endif %}
            <div class="mt-2">
              <h3 class="font-semibold text-sm line-clamp-2 leading-tight">{{ movie.data.title }}</h3>
              {% if movie.data.director %}
                <p class="text-[var(--text-secondary)] text-xs">{{ movie.data.director }}</p>
              {% endif %}
              {% if movie.data.rating %}
                <p class="flex items-center gap-1 text-yellow-500 text-xs">
                  {% for i in range(1, 6) %}
                    {% if i <= movie.data.rating %}⭐{% endif %}
                  {% endfor %}
                </p>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </section>
{% else %}
  <p class="py-12 text-[var(--text-secondary)] text-center">
    Nenhum filme registrado ainda.
  </p>
{% endfor %}
