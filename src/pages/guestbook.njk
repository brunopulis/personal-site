---
layout: base.njk
permalink: '/guestbook/'
title: Livro de visitas
---

<div class="max-w-4xl">
  <h1 class="mb-2 font-bold text-3xl">
    <span aria-hidden="true">📖</span> Livro de visitas
  </h1>
  <p class="mb-8 text-gray-600">
    Deixe sua marca! Escreva uma mensagem, um conselho, ou só um "oi" mesmo.
  </p>

  <section class="bg-light-silver-100 mb-8 p-6 border border-light-silver-200 rounded-lg">
    <h2 class="mb-4 font-semibold text-blood-red-950 text-lg">Deixe sua mensagem</h2>
    <form id="guestbook-form" class="space-y-4">
      <div>
        <label for="name" class="block mb-1 font-medium text-sm">Nome</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          maxlength="100"
          class="bg-white px-3 py-2 border border-light-silver-300 rounded focus:outline-none focus:ring-2 focus:ring-vista-blue-500 w-full"
          placeholder="Seu nome"
        />
      </div>

      <div>
        <label for="message" class="block mb-1 font-medium text-sm">Mensagem</label>
        <textarea
          id="message"
          name="message"
          required
          maxlength="2000"
          rows="4"
          class="bg-white px-3 py-2 border border-light-silver-300 rounded focus:outline-none focus:ring-2 focus:ring-vista-blue-500 w-full"
          placeholder="Escreva sua mensagem..."
        ></textarea>
      </div>

      <div aria-hidden="true" class="hidden">
        <label for="honeypot">Não preencha</label>
        <input type="text" id="honeypot" name="honeypot" tabindex="-1" autocomplete="off" />
      </div>

      <div id="form-feedback" class="hidden"></div>

      <button
        type="submit"
        class="bg-blood-red-950 hover:bg-blood-red-900 px-4 py-2 rounded font-bold text-white transition-colors"
      >
        Enviar mensagem
      </button>
    </form>
  </section>

  <section>
    <h2 class="mb-4 font-semibold text-blood-red-950 text-xl">
      Mensagens
      <span id="message-count" class="font-normal text-gray-500 text-base">({{ guestbook.messages.length }})</span>
    </h2>

    {% if guestbook.messages.length == 0 %}
      <p id="empty-state" class="py-8 text-gray-500 text-center">
        Nenhuma mensagem ainda. Seja o primeiro a escrever!
      </p>
    {% endif %}

    <div id="messages-list" class="space-y-4">
      {% for entry in guestbook.messages | reverse %}
        <article class="bg-light-silver-100 p-4 border border-light-silver-200 rounded-lg">
          <div class="flex justify-between items-start mb-2">
            <strong class="text-blood-red-950">{{ entry.name }}</strong>
            <time datetime="{{ entry.timestamp }}" class="text-gray-500 text-xs">
              {{ entry.timestamp | readableDate }}
            </time>
          </div>
          <p class="text-errie-black-900">{{ entry.message }}</p>
        </article>
      {% endfor %}
    </div>
  </section>
</div>

<script src="/assets/js/guestbook.js" defer></script>
