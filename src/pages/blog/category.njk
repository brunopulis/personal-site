---
layout: base.njk
title: "Posts em {{ category.name }}"
pagination:
  data: collections.catpages
  size: 1
  alias: category
permalink: "/blog/category/{{ category.slug }}/index.html"
---

<h1>Posts em {{ category.name }}</h1>

{% set catPosts = collections.posts | where('data.category', category.name) %}

<ul>
{% for post in catPosts %}
  <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
{% endfor %}
</ul>

<nav>
  <a href="/blog/">Todos os posts</a>
</nav>
