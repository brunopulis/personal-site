---
layout: base.njk
pagination:
  data: collections.posts
  size: 10
  alias: posts
permalink: '/blog/{% if pagination.pageNumber >= 1 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}index.html'
title: Blog
---

<div class="h-feed">
  <h1 class="mb-6 p-name font-bold text-blood-red-950 text-2xl">Blog</h1>
  <a class="hidden u-url" href="{{ site.url }}/blog/"></a>
  <p class="pb-4">Artigos e conteúdos longos sobre diversas coisas.</p>

  <p class="pb-4">Filtre pelas categorias:</p>
  <nav class="mb-8">
    <ul class="inline-flex gap-2">
      <li>
        <a
          href="/blog/"
          class="bg-blood-red-950 px-3 py-1.5 border border-blood-red-950 rounded-full font-semibold text-white text-xs transition-colors"
        >
          Todas
        </a>
      </li>
      {% for category in collections.catpages -%}
        <li>
          <a
            href="/blog/category/{{ category.slug }}/"
            class="bg-transparent hover:bg-blood-red-950 px-3 py-1.5 border border-light-silver-300 rounded-full font-semibold text-errie-black-950 hover:text-white text-xs transition-colors"
          >
            {{ category.name }}
          </a>
        </li>
      {%- endfor %}
    </ul>
  </nav>

  <div class="space-y-8" id="posts-list">
    {% for post in posts %}
      {% set tags = (post.data and post.data.tags) or post.tags or [] %}
      {% set postCategory = (post.data and post.data.category) or '' %}
      <article class="pb-6 border-b h-entry">
        <h3 class="p-name font-semibold text-xl">
          <a class="u-url" href="{{ post.url }}">{{ post.data.title }}</a>
        </h3>
        <time
          class="text-sm dt-published"
          datetime="{{ post.date | htmlDateString }}">
          {{ post.date | readableDate }}
        </time>
        <p class="mt-2 p-summary">
          {{ post.data.description or (post.templateContent | striptags | truncate(160)) }}
        </p>
        {% if tags %}
          <div class="inline-flex gap-2 py-4">
            <svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle></svg>
            <div class="flex flex-wrap gap-2">
              {% for tag in tags %}
                <a
                  class="p-category font-bold text-errie-black-950 text-xs transition-colors"
                  href="/tags/{{ tag | slug }}/"
                  >#{{ tag }}</a
                >
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </article>
    {% endfor %}
  </div>

  <nav class="flex justify-between items-center mt-8" aria-label="Pagination">
    {% if pagination.href.previous %}
      <a class="bg-blood-red-950 hover:bg-blood-red-900 px-3 py-2 border rounded font-bold text-white" href="{{ pagination.href.previous }}" rel="prev">Anterior</a>
    {% else %}
      <span></span>
    {% endif %}
    {% if pagination.href.next %}
      <a class="bg-blood-red-950 hover:bg-blood-red-900 px-3 py-2 border rounded font-bold text-white" href="{{ pagination.href.next }}" rel="next">Próximo</a>
    {% endif %}
  </nav>
</div>

