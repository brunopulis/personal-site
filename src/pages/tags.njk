---
layout: base
title: Tags
description: Todas as tags do meu conteúdo
permalink: /tags/
eleventyComputed:
  title: Tags
---

<div class="wrapper region">
  <header class="flow">
    <h1 class="p-name">{{ title }}</h1>
    <p>{{ description }}</p>
  </header>

  <div class="flow prose">
    {% if collections.tagsWithCount and collections.tagsWithCount.length %}
      <ul>
        {% for t in collections.tagsWithCount %}
          <li>
            <a href="/tag/{{ t.slug }}/">#{{ t.tag }}</a>
            <span>{{ t.count }} post{{ 's' if t.count != 1 }}</span>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>Nenhuma tag encontrada.</p>
    {% endif %}
  </div>
</div>
