---
layout: tags
permalink: /tags/index.html
eleventyComputed:
  title: '{{ meta.blog.tagPlural }}'
---

<h1>Todas as Tags</h1>

<div class="tag-cloud">
  {% for tag in collections.tagList %}
    <a href="/tags/{{ tag | slugify }}/" class="tag-link">{{ tag }}</a>
  {% endfor %}
</div>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const filterTag = urlParams.get('tag');

  if (filterTag) {
    document.querySelectorAll('.tag-link').forEach(link => {
      if (link.textContent.trim() !== filterTag) {
        link.closest('article, li').style.display = 'none';
      }
    });
  }
</script>
