---json
{
  "permalink": "/feeds/games/rss.xml",
  "eleventyExcludeFromCollections": true,
  "metadata": {
    "title": "Bruno Pulis - Jogos",
    "description": "Minha coleção de jogos ao longo dos anos",
    "language": "pt-br",
    "base": "https://www.brunopulis.com",
    "author": {
      "name": "Bruno Pulis",
      "email": "brunopulis@protonmail.com"
    }
  }
}
---
<?xml version="1.0" encoding="utf-8"?>
<?xml-stylesheet href="/feeds/pretty-feed-v3.xsl" type="text/xsl"?>
<rss version="2.0" xmlns:dc="http://purl.org/dc/elements/1.1/" xml:base="{{ metadata.base | addPathPrefixToFullUrl }}"
  xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ metadata.title }}</title>
    <link>{{ metadata.base | addPathPrefixToFullUrl }}</link>
    <atom:link href="{{ permalink | htmlBaseUrl(metadata.base) }}" rel="self" type="application/rss+xml" />
    <description>{{ metadata.description }}</description>
    <language>{{ metadata.language or page.lang }}</language>
    {%- set games = collections.games %}
    {%- for game in games | reverse | limit(10) %}
    {%- set absolutePostUrl = game.url | htmlBaseUrl(metadata.base) %}
    <item>
      <title>{{ game.data.title }}</title>
      <link>{{ absolutePostUrl }}</link>
      <description>{{ game.content | renderTransforms(game.data.page, metadata.base) }}</description>
      <pubDate>{{ (game.data.releaseDate or game.date) | toRfc822Date }}</pubDate>
      <dc:creator>{{ metadata.author.name }}</dc:creator>
      <guid>{{ absolutePostUrl }}</guid>
      {%- if game.data.tags %}
      {%- for tag in game.data.tags %}
      {%- if tag not in ["games", "all"] %}
      <category>{{ tag }}</category>
      {%- endif %}
      {%- endfor %}
      {%- endif %}
    </item>
    {%- endfor %}
  </channel>
</rss>
