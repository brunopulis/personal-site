---json
{
  "permalink": "/feeds/games/atom.xml",
  "eleventyExcludeFromCollections": true,
  "metadata": {
    "title": "Bruno Pulis - Jogos",
    "description": "Minha coleção de jogos ao longo dos anos",
    "language": "pt-br",
    "base": "https://www.brunopulis.com",
    "author": {
      "name": "Bruno Pulis",
      "email": "brunopulis@protonmail.com"
    }
  }
}
---

<?xml version="1.0" encoding="UTF-8"?> <?xml-stylesheet href="/feeds/pretty-feed-v3.xsl" type="text/xsl"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ metadata.language }}">
  <title>{{ metadata.title }}</title>
  <subtitle>{{ metadata.subtitle }}</subtitle>
  <link href="{{ permalink | htmlBaseUrl(metadata.base) }}" rel="self" />
  <link href="{{ metadata.base | addPathPrefixToFullUrl }}" />
  <updated>{{ collections.games | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ metadata.base | addPathPrefixToFullUrl }}</id>
  <author>
    <name>{{ metadata.author.name }}</name>
    <email>{{ metadata.author.email }}</email>
  </author>

  {%- for game in collections.games | limit(10) %}
    {%- set absolutePostUrl = game.url | htmlBaseUrl(metadata.base) %}
    <entry>
      <title>{{ game.data.title }}</title>
      <link href="{{ absolutePostUrl }}" />
      <updated>{{ (game.data.pubDate or game.date) | dateToRfc3339 }}</updated>
      <id>{{ absolutePostUrl }}</id>
      <content xml:lang="{{ metadata.language }}" type="html">{{ game.content | safe }}</content>
      {%- if game.data.summary %}
        <summary>{{ game.data.summary }}</summary>
      {%- endif %}
      {%- if game.data.tags %}
        {%- for tag in game.data.tags %}
          <category term="{{ tag }}" />
        {%- endfor %}
      {%- endif %}
    </entry>
  {%- endfor %}
</feed>
