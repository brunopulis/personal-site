---json
{
  "permalink": "/feeds/games/feed.json",
  "eleventyExcludeFromCollections": true,
  "metadata": {
    "title": "Bruno Pulis - Jogos",
    "description": "Minha coleção de jogos ao longo dos anos",
    "language": "pt-br",
    "base": "https://www.brunopulis.com",
    "author": {
      "name": "Bruno Pulis",
      "email": "brunopulis@protonmail.com"
    }
  }
}
---

{ "version": "https://jsonfeed.org/version/1.1", "title": "{{ metadata.title }} - Blog", "description":
"{{ metadata.description }}", "home_page_url": "{{ metadata.base | addPathPrefixToFullUrl }}", "feed_url":
"{{ permalink | htmlBaseUrl(metadata.base) }}", "language": "{{ metadata.language }}", "authors": [ { "name":
"{{ metadata.author.name }}", "url": "{{ metadata.base | addPathPrefixToFullUrl }}" } ], "items": [
{%- for game in collections.games | reverse | limit(10) %}
  {%- set absolutePostUrl = game.url | htmlBaseUrl(metadata.base) %}
  { "id": "{{ absolutePostUrl }}", "url": "{{ absolutePostUrl }}", "title":
  {{ game.data.title | dump | safe }}, "content_html":
  {{ game.templateContent | htmlToAbsoluteUrls(absolutePostUrl) | dump | safe }},
  {%- if game.data.summary %}
    "summary": {{ game.data.summary | dump | safe }},
  {%- endif %}
  "date_published": "{{ game.date | toRfc822Date }}", "date_modified":
  "{{ game.data.updated | default(game.date) | toRfc822Date }}"
  {%- if game.data.tags %}
    , "tags": {{ game.data.tags | dump | safe }}
  {%- endif %}
  } {% if not loop.last %},{% endif %}
{%- endfor %}
] }
