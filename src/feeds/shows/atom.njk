---json
{
  "permalink": "/feeds/shows/atom.xml",
  "eleventyExcludeFromCollections": true,
  "metadata": {
    "title": "Bruno Pulis - Seriados",
    "description": "Minha coleção de seriados",
    "language": "pt-br",
    "base": "https://www.brunopulis.com",
    "author": {
      "name": "Bruno Pulis",
      "email": "brunopulis@protonmail.com"
    }
  }
}
---

<?xml version="1.0" encoding="UTF-8"?> <?xml-stylesheet href="/feeds/pretty-feed-v3.xsl" type="text/xsl"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ metadata.language }}">
  <title>{{ metadata.title }}</title>
  <subtitle>{{ metadata.subtitle }}</subtitle>
  <link href="{{ permalink | htmlBaseUrl(metadata.base) }}" rel="self" />
  <link href="{{ metadata.base | addPathPrefixToFullUrl }}" />
  <updated>{{ collections.shows | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ metadata.base | addPathPrefixToFullUrl }}</id>
  <author>
    <name>{{ metadata.author.name }}</name>
    <email>{{ metadata.author.email }}</email>
  </author>

  {%- for show in collections.shows | limit(10) %}
    {%- set absoluteShowUrl = show.url | htmlBaseUrl(metadata.base) %}
    <entry>
      <title>{{ show.data.title }}</title>
      <link href="{{ absoluteShowUrl }}" />
      <updated>{{ (show.data.watchedDate or show.date) | dateToRfc3339 }}</updated>
      <id>{{ absoluteShowUrl }}</id>
      <content xml:lang="{{ metadata.language }}" type="html">{{ show.content | safe }}</content>
      {%- if show.data.category %}
        <category term="{{ show.data.category }}" />
      {%- endif %}
      {%- if show.data.status %}
        <category term="{{ show.data.status }}" />
      {%- endif %}
    </entry>
  {%- endfor %}
</feed>