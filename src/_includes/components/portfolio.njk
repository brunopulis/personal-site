<section class="wrapper" aria-labelledby="portfolio-title">
  <header class="region | flow">
    <h2 id="portfolio-title">Portfólio</h2>
    <p>Alguns trabalhos que realizei</p>
  </header>

  <div class="grid" data-layout="33x3">
    {% set projects = portfolio.projects %}
    {% for project in projects.slice(0, 3) %}
    <article class="card">
      <img alt="{{ project.imageAlt }}" src="{{ project.image }}" />

      <div class="flow">
        <h3>{{ project.title }}</h3>
        <p>{{ project.description }}</p>
      </div>
    </article>
    {% endfor %}
  </div>
  <div class="region | flow">
    <a href="/portfolio" class="button">
      ver todos projetos <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </a>
  </div>
</section>