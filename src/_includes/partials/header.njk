<header class="bg-light-silver-100 border-gray-200 border-b">
  <div class="flex justify-between items-center gap-4 mx-auto px-4 py-3 max-w-4xl">
    <a class="font-semibold text-lg" href="/">
      <img src="/assets/images/pulis-8bits.png" alt="" class="rounded-full" style="max-width: 100%; width: 64px; height: 64px;">
    </a>
    <nav aria-label="Navegação principal">
      <div id="primary-nav" class="hidden md:block">
        {% set url = page.url or '/' %}
        {% set isBlog = (url and (url | slice(0, 6) == '/blog/')) %}
        {% set isBiblioteca = (url and (url | slice(0, 11) == '/bookshelf/' or url | slice(0, 10) == '/watching/' or url | slice(0, 7) == '/games/' or url | slice(0, 13) == '/newsletters/')) %}
        {% set isSobre = (url == '/about/' or url == '/now/' or url == '/uses/') %}
        {% set isExplore = url == '/explore/' %}
        {% set isNotes = url == '/notes/' %}

        <ul class="flex md:flex-row flex-col md:items-center md:space-x-1 space-y-1 md:space-y-0 md:text-sm text-base">
          <li>
            <a href="/blog/" class="nav-item block px-3 py-2 underline hover:no-underline {% if isBlog %}underline font-semibold{% endif %}"
              {% if isBlog %}aria-current="page"{% endif %}>Blog</a>
          </li>

          <li class="relative dropdown">
            <button type="button" class="dropdown-toggle nav-item flex items-center gap-1 w-full md:w-auto px-3 py-2 underline hover:no-underline {% if isBiblioteca %}underline font-semibold{% endif %}"
              aria-haspopup="true" aria-expanded="false"
              {% if isBiblioteca %}aria-current="page"{% endif %}>
              Conteúdos
              <svg class="mt-0.5 w-3 h-3 transition-transform dropdown-arrow" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <ul class="hidden md:top-full md:left-0 md:z-50 md:absolute space-y-1 md:space-y-0 md:bg-white md:shadow-lg md:mt-1 md:py-1 pl-4 md:pl-0 md:border md:border-gray-200 md:rounded-lg md:min-w-[180px] dropdown-menu" role="list">
              <li><a href="/bookshelf/" class="block px-4 py-2 underline hover:no-underline hover:bg-light-silver-100 {% if url | slice(0, 11) == '/bookshelf/' %}font-semibold{% endif %}"
                {% if url | slice(0, 11) == '/bookshelf/' %}aria-current="page"{% endif %}>Livros</a></li>
              <li><a href="/watching/" class="block px-4 py-2 underline hover:no-underline hover:bg-light-silver-100 {% if url | slice(0, 10) == '/watching/' %}font-semibold{% endif %}"
                {% if url | slice(0, 10) == '/watching/' %}aria-current="page"{% endif %}>Filmes e Séries</a></li>
              <li><a href="/games/" class="block px-4 py-2 underline hover:no-underline hover:bg-light-silver-100 {% if url | slice(0, 7) == '/games/' %}font-semibold{% endif %}"
                {% if url | slice(0, 7) == '/games/' %}aria-current="page"{% endif %}>Jogos</a></li>
              <li><a href="/newsletters/" class="block px-4 py-2 underline hover:no-underline hover:bg-light-silver-100 {% if url | slice(0, 13) == '/newsletters/' %}font-semibold{% endif %}"
                {% if url | slice(0, 13) == '/newsletters/' %}aria-current="page"{% endif %}>Newsletter</a></li>
            </ul>
          </li>

          <li class="relative dropdown">
            <button type="button" class="dropdown-toggle nav-item flex items-center gap-1 w-full md:w-auto px-3 py-2 underline hover:no-underline {% if isSobre %}underline font-semibold{% endif %}"
              aria-haspopup="true" aria-expanded="false"
              {% if isSobre %}aria-current="page"{% endif %}>
              Sobre
              <svg class="mt-0.5 w-3 h-3 transition-transform dropdown-arrow" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <ul class="hidden md:top-full md:left-0 md:z-50 md:absolute space-y-1 md:space-y-0 md:bg-white md:shadow-lg md:mt-1 md:py-1 pl-4 md:pl-0 md:border md:border-gray-200 md:rounded-lg md:min-w-[160px] dropdown-menu" role="list">
              <li><a href="/about/" class="block px-4 py-2 underline hover:no-underline hover:bg-light-silver-100 {% if url == '/about/' %}font-semibold{% endif %}"
                {% if url == '/about/' %}aria-current="page"{% endif %}>Sobre</a></li>
              <li><a href="/now/" class="block px-4 py-2 underline hover:no-underline hover:bg-light-silver-100 {% if url == '/now/' %}font-semibold{% endif %}"
                {% if url == '/now/' %}aria-current="page"{% endif %}>Agora</a></li>
              <li><a href="/uses/" class="block px-4 py-2 underline hover:no-underline hover:bg-light-silver-100 {% if url == '/uses/' %}font-semibold{% endif %}"
                {% if url == '/uses/' %}aria-current="page"{% endif %}>O que uso</a></li>
            </ul>
          </li>

          <li>
            <a href="/explore/" class="nav-item block px-3 py-2 underline hover:no-underline {% if isExplore %}underline font-semibold{% endif %}"
              {% if isExplore %}aria-current="page"{% endif %}>Explore</a>
          </li>
        </ul>
      </div>
    </nav>
    <button id="hamburger" class="md:hidden p-2 border border-gray-300 rounded" aria-label="Abrir ou fechar menu" aria-controls="primary-nav" aria-expanded="false">
      <span class="block bg-gray-700 mb-1 w-5 h-0.5 transition-transform bar-1"></span>
      <span class="block bg-gray-700 mb-1 w-5 h-0.5 transition-opacity bar-2"></span>
      <span class="block bg-gray-700 w-5 h-0.5 transition-transform bar-3"></span>
    </button>
  </div>
</header>
