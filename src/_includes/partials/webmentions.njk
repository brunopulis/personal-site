<section id="webmentions" class="mt-12">
  <h2 class="mb-4 font-semibold text-blood-red-950 text-xl">
    Respostas via <em>webmention's</em>
  </h2>
  <div class="py-4" id="webmentions-list">
    <p class="animate-pulse">Carregando <em lang="en">webmentions</em>...</p>
  </div>
</section>

{% if webmentions and webmentions.length > 0 %}
  <div class="space-y-4">
    {% for mention in webmentions %}
      <article class="p-4 border border-gray-200 rounded-lg">
        <div class="flex items-start space-x-3">
          {% if mention.author.photo %}
            <img
              src="{{ mention.author.photo }}"
              alt="{{ mention.author.name }}"
              class="rounded-full w-10 h-10"
            />
          {% else %}
            <div class="flex justify-center items-center bg-gray-300 rounded-full w-10 h-10">
              <span class="font-medium text-sm">
                {{ mention.author.name | first }}
              </span>
            </div>
          {% endif %}
          <div class="flex-1 min-w-0">
            <div class="flex items-center space-x-2 text-sm">
              <a
                href="{{ mention.author.url }}"
                class="font-medium hover:text-blue-600"
                target="_blank"
                rel="noopener"
              >
                {{ mention.author.name }}
              </a>
              <span>
                {% if mention['wm-property'] == 'like-of' %}
                  gostei disso
                {% elif mention['wm-property'] == 'repost-of' %}
                  repostei isso
                {% elif mention['wm-property'] == 'bookmark-of' %}
                  favoritei isso
                {% elif mention['wm-property'] == 'mention-of' %}
                  mencionei isso
                {% else %}
                  respondi
                {% endif %}
              </span>
              <time class="text-gray-500" datetime="{{ mention.published }}">
                {{ mention.published | readableDate }}
              </time>
            </div>
            {% if mention.content and mention.content.text %}
              <div class="mt-2">
                {{ mention.content.text | truncate(280) | safe }}
              </div>
            {% endif %}
            <div class="mt-2">
              <a
                href="{{ mention.url }}"
                class="text-blue-600 hover:text-blue-800 text-sm"
                target="_blank"
                rel="noopener"
              >
                Ver o original
              </a>
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
{% else %}
  <div class="py-8">
    <p>Ainda não há menções via webmention. Seja o primeiro a responder!</p>
    <p class="mt-2 text-sm">
      <a
        href="https://indieweb.org/Webmention"
        target="_blank"
        rel="noopener noreferrer"
        class="text-blood-red-950 underline hover:no-underline"
      >
        Aprenda sobre <em>webmentions</em>
      </a>
    </p>
  </div>
{% endif %}
