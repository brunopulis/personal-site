<section id="webmentions" class="mt-12">
  <h2 class="mb-4 font-semibold text-xl">Respostas</h2>
  <div id="webmentions-list">
    <div class="py-4 text-gray-500 text-center">
      <div class="animate-pulse">Carregando <em lang="en">webmentions</em>...</div>
    </div>
  </div>
</section>

{% if webmentions and webmentions.length > 0 %}
  <div class="space-y-4">
    {% for mention in webmentions %}
      <article class="p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
        <div class="flex items-start space-x-3">
          {% if mention.author.photo %}
            <img
              src="{{ mention.author.photo }}"
              alt="{{ mention.author.name }}"
              class="rounded-full w-10 h-10"
            />
          {% else %}
            <div class="flex justify-center items-center bg-gray-300 dark:bg-gray-600 rounded-full w-10 h-10">
              <span class="font-medium text-sm">{{ mention.author.name | first }}</span>
            </div>
          {% endif %}
          <div class="flex-1 min-w-0">
            <div class="flex items-center space-x-2 text-sm">
              <a
                href="{{ mention.author.url }}"
                class="font-medium hover:text-blue-600"
                target="_blank"
                rel="noopener"
              >
                {{ mention.author.name }}
              </a>
              <span class="text-gray-500">
                {% if mention['wm-property'] == 'like-of' %}
                  liked this
                {% elif mention['wm-property'] == 'repost-of' %}
                  reposted this
                {% elif mention['wm-property'] == 'bookmark-of' %}
                  bookmarked this
                {% elif mention['wm-property'] == 'mention-of' %}
                  mentioned this
                {% else %}
                  replied
                {% endif %}
              </span>
              <time class="text-gray-500" datetime="{{ mention.published }}">
                {{ mention.published | readableDate }}
              </time>
            </div>
            {% if mention.content and mention.content.text %}
              <div class="mt-2 text-gray-700 dark:text-gray-300">
                {{ mention.content.text | truncate(280) | safe }}
              </div>
            {% endif %}
            <div class="mt-2">
              <a
                href="{{ mention.url }}"
                class="text-blue-600 hover:text-blue-800 text-sm"
                target="_blank"
                rel="noopener"
              >
                View original
              </a>
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
{% else %}
  <div class="py-8 text-gray-500 text-center">
    <p>No webmentions yet. Be the first to respond!</p>
    <p class="mt-2 text-sm">
      <a
        href="https://indieweb.org/Webmention"
        target="_blank"
        rel="noopener"
        class="text-blue-600 hover:text-blue-800"
      >
        Learn about webmentions
      </a>
    </p>
  </div>
{% endif %}
