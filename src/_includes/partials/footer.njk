<footer class="bg-light-silver-100 mt-12 border-gray-200 border-t">
  <div class="mx-auto px-4 py-8 max-w-4xl container">
    <div class="justify-around gap-2 grid grid-cols-1 md:grid-cols-2">
      <div>
        <h3 class="font-semibold">Links</h3>
        <ul class="flex gap-2 mt-2 text-sm leading-relaxed">
          <li><a href="/explore/" class="text-errie-black-950 underline hover:no-underline">Explore</a></li>
          <li><a href="/archive/" class="text-errie-black-950 underline hover:no-underline">Arquivo</a></li>
          <li><a href="/guestbook/" class="text-errie-black-950 underline hover:no-underline">Livro de visitas</a></li>
          <li><a href="/accessibility/" class="text-errie-black-950 underline hover:no-underline">Acessibilidade</a></li>
          <li><a href="/stats/" class="text-errie-black-950 underline hover:no-underline">Estatísticas</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold">Se conecte</h3>
        <ul class="flex gap-2 mt-2 text-sm leading-relaxed">
          {% if site.social.github %}
          <li>
            <a href="https://github.com/{{ site.social.github }}" target="_blank" rel="me noopener noreferrer" class="text-errie-black-950 hover:text-errie-black-900 underline">
              GitHub
            </a>
          </li>
          {% endif %}

          {% if site.social.bluesky %}
          <li>
            <a href="{{ site.social.bluesky }}" target="_blank" rel="me noopener noreferrer" class="text-errie-black-950 hover:text-errie-black-900 underline">
              Bluesky
            </a>
          </li>
          {% endif %}

          {% if site.social.mastodon %}
          <li>
            <a href="{{ site.social.mastodon }}" target="_blank" rel="me noopener noreferrer" class="text-errie-black-950 hover:text-errie-black-900 underline">
              Mastodon
            </a>
          </li>
          {% endif %}

          {% if site.social.youtube %}
          <li>
            <a href="{{ site.social.youtube }}" target="_blank" rel="me noopener noreferrer" class="text-errie-black-950 hover:text-errie-black-900 underline">
              YouTube
            </a>
          </li>
          {% endif %}

          {% if site.social.linkedin %}
          <li>
            <a href="{{ site.social.linkedin }}" target="_blank" rel="me noopener noreferrer" class="text-errie-black-950 hover:text-errie-black-900 underline">
              LinkedIn
            </a>
          </li>
          {% endif %}
        </ul>
      </div>
    </div>
    <hr class="mt-6 pt-6 border-gray-200 border-t">

    {% include "partials/webrings.njk" %}
    <hr class="mt-6 pt-6 border-gray-200 border-t">
    {% include "partials/badges.njk" %}
    <hr class="mt-6 pt-6 border-gray-200 border-t">

    <p class="text-errie-black-950 text-sm text-center">
      2012 {{ site.name }} •
      <a href="/feed.xml" class="underline hover:no-underline">RSS</a> •
      Código: <a href="https://opensource.org/license/mit" target="_blank" rel="noopener" class="underline hover:no-underline">MIT</a> •
      Conteúdo: <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener" class="underline hover:no-underline">CC BY-NC-SA 4.0</a>
    </p>
  </div>
</footer>

<script src="/assets/js/main.js" defer></script>
