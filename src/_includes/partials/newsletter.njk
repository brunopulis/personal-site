<section class="flex items-start gap-4 mt-10 p-5 border border-border rounded-md">
  <div>
    <h2 class="mb-2 font-semibold text-blood-red-950 text-lg">
      {{ site.newsletter.title }}
    </h2>
    <p class="mb-4">
      {{ site.newsletter.description }}
    </p>

    <a href="{{ site.newsletter.action }}"
       rel="noopener noreferrer"
       target="_blank"
       class="my-2 p-3 font-bold text-blood-red-950 hover:text-blood-red-900 underline underline-offset-4 hover:no-underline">
      Se inscreva
    </a>
  </div>
</section>
