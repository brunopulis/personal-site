<!doctype html>
<html lang="pt-br" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% if title %}
  <title>{{ title }} — {{ site.name }}</title>
  {% else %}
  <title>{{ site.name }}</title>
  {% endif %}
  <meta name="description" content="{{ description or site.description }}" />
  <meta name="generator" content="Eleventy" />
  {# Canonical URL #}
  {% if site.url %}
  <link rel="canonical" href="{{ site.url }}{{ page.url or '/' }}" />
  {% endif %}

  {# Open Graph (Facebook, LinkedIn, etc.) #}
  {% set ogTitle = title or site.name %}
  {% set ogDescription = description or site.description %}
  {% set ogUrl = (site.url and (site.url + (page.url or '/'))) or '' %}
  {# Resolve image: allow per-page front matter `image` or default to /screenshot.png #}
  {% set rawImage = image or '/screenshot.png' %}
  {% if site.url %}
    {% if rawImage | slice(0,4) == 'http' %}
      {% set ogImage = rawImage %}
    {% elseif rawImage | slice(0,1) == '/' %}
      {% set ogImage = site.url + rawImage %}
    {% else %}
      {% set ogImage = site.url + '/' + rawImage %}
    {% endif %}
  {% else %}
    {% set ogImage = rawImage %}
  {% endif %}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="{{ site.name }}" />
  {% if ogUrl %}<meta property="og:url" content="{{ ogUrl }}" />{% endif %}
  <meta property="og:title" content="{{ ogTitle }}" />
  <meta property="og:description" content="{{ ogDescription }}" />
  <meta property="og:image" content="{{ ogImage }}" />
  <meta property="og:image:alt" content="{{ site.name }} preview" />

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image" />
  {% if site.social and site.social.twitter %}
    <meta name="twitter:site" content="{{ site.social.twitter }}" />
    <meta name="twitter:creator" content="{{ site.social.twitter }}" />
  {% endif %}
  <meta name="twitter:title" content="{{ ogTitle }}" />
  <meta name="twitter:description" content="{{ ogDescription }}" />
  <meta name="twitter:image" content="{{ ogImage }}" />
  <meta name="twitter:image:alt" content="{{ site.name }} preview" />
  <link rel="webmention" href="https://webmention.io/{{ site.url | replace('https://', '') | replace('http://', '') }}/webmention" />
  <link rel="pingback" href="https://webmention.io/{{ site.url | replace('https://', '') | replace('http://', '') }}/xmlrpc" />
  <link rel="stylesheet" href="/assets/css/build.css" />


  <!-- RSS Autodiscovery. Loops over meta.blog.feedLinks -->
  {% for feedLink in meta.blog.feedLinks %}
    <link
      rel="alternate"
      type="{{ feedLink.type }}"
      title="{{ feedLink.title }}: {{ meta.siteName }}"
      href="{{ feedLink.url }}"
    />
  {% endfor %}

  {# Favicon and theme color #}
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="shortcut icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="mask-icon" href="/assets/favicon.svg" color="#a78bfa">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
  <meta name="theme-color" content="#a78bfa" />
  <link rel="manifest" href="/manifest.webmanifest">

  {# Syntax highlighting via Highlight.js local #}
  <link id="hljs-light" rel="stylesheet" href="/assets/css/highlight/tokyo-night-light.min.css">
  <link id="hljs-dark" rel="stylesheet" href="/assets/css/highlight/tokyo-night-dark.min.css" disabled>

  <script src="/assets/js/highlight.min.js" defer></script>
  <script defer>
    document.addEventListener('DOMContentLoaded', function () {
      const html = document.documentElement;
      const light = document.getElementById('hljs-light');
      const dark = document.getElementById('hljs-dark');
      function applyTheme() {
        const isDark = html.classList.contains('dark');
        if (light && dark) {
          light.disabled = !!isDark;
          dark.disabled = !isDark;
        }
      }
      // Initial apply
      applyTheme();
      // Observe class changes on <html> to react to dark-mode toggle
      const observer = new MutationObserver(applyTheme);
      observer.observe(html, { attributes: true, attributeFilter: ['class'] });
      // Highlight code blocks
      document.querySelectorAll('pre code').forEach((el) => {
        if (window.hljs && typeof window.hljs.highlightElement === 'function') {
          window.hljs.highlightElement(el);
        }
      });
    });
  </script>
  <style>
    .contrast { filter: contrast(1.2) saturate(1.1); }
    .reduce-motion * { transition: none !important; animation: none !important; }
  </style>
  {% include "partials/analytics.njk" %}

  {# SEO: Structured Data (JSON-LD) #}
  {% if site.url %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "url": "{{ site.url }}",
        "name": "{{ site.name }}",
        "description": "{{ site.description }}"
      },
      {
        "@type": "Organization",
        "name": "{{ site.author }}",
        "url": "{{ site.url }}",
        "sameAs": [
          {% set sameAs = [] %}
          {% if site.social and site.social.github %}
            {% set sameAs = sameAs.concat(['https://github.com/' + site.social.github]) %}
          {% endif %}
          {% if site.social and site.social.twitter %}
            {% set sameAs = sameAs.concat(['https://twitter.com/' + (site.social.twitter | replace('@',''))]) %}
          {% endif %}
          {% for link in sameAs %}
            "{{ link }}"{% if not loop.last %},{% endif %}
          {% endfor %}
        ]
      }
    ]
  }
  </script>

  {# Breadcrumbs: Home > Current #}
  {% set isHome = (page.url or '/') == '/' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ site.url }}"
      }{% if not isHome %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "{{ title or site.name }}",
        "item": "{{ site.url }}{{ page.url or '/' }}"
      }
      {% endif %}
    ]
  }
  </script>

  {# BlogPosting for content pages (#blog, #notes, #poetry, #journal) #}
  {% set url = page.url or '/' %}
  {% set isPostLike = (url | slice(0,6) == '/blog/' ) or (url | slice(0,7) == '/notes/' ) or (url | slice(0,8) == '/poetry/' ) or (url | slice(0,9) == '/journal/' ) %}
  {% if isPostLike %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ (site.url and (site.url + (page.url or '/'))) or '' }}"
    },
    "headline": "{{ title or site.name }}",
    {% if ogImage %}"image": ["{{ ogImage }}"],{% endif %}
    "datePublished": "{{ page.date | htmlDateString }}",
    "dateModified": "{{ page.date | htmlDateString }}",
    "author": {
      "@type": "Person",
      "name": "{{ author or site.author }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.name }}"
    },
    "description": "{{ description or site.description }}"
  }
  </script>
  {% endif %}
  {% endif %}
</head>
<body class="flex flex-col bg-[var(--bg)] min-h-screen text-[var(--text)]">
  <a href="#main-content" class="sr-only">Ir para conteúdo principal</a>
  <div id="progress-bar" aria-hidden="true"></div>
  <header class="bg-[var(--surface)] border-gray-200 dark:border-gray-700 border-b">
    <div class="flex items-center gap-3 mx-auto px-4 py-3 container">
      <a class="font-semibold text-lg" href="/">
        <img src="/assets/images/pulis.webp" alt="" srcset="" style="max-width: 100%; width: 64px; height: 64px; border-radius: 50%;">
      </a>
      <form class="hidden sm:block ml-auto" role="search" aria-label="Site" action="/search/" method="get">
        <label class="sr-only" for="q">Pesquisar</label>
        <input id="q" name="q" type="search" placeholder="pesquise um termo..." class="px-3 py-2 border rounded w-64" />
      </form>
      <button id="hamburger" class="md:hidden p-2 border border-gray-300 dark:border-gray-600 rounded" aria-label="Toggle menu" aria-controls="primary-nav" aria-expanded="false">
        <span class="block bg-gray-700 dark:bg-gray-200 mb-1 w-5 h-0.5 transition-transform bar-1"></span>
        <span class="block bg-gray-700 dark:bg-gray-200 mb-1 w-5 h-0.5 transition-opacity bar-2"></span>
        <span class="block bg-gray-700 dark:bg-gray-200 w-5 h-0.5 transition-transform bar-3"></span>
      </button>
    </div>
  </header>

  <nav class="bg-[var(--surface)] border-gray-200 dark:border-gray-700 border-b">
    <div id="primary-nav" class="hidden md:block mx-auto px-4 py-2 container">
      {% set url = page.url or '/' %}
      {% set isHome = url == '/' %}
      {% set isBlog = (url and (url | slice(0, 6) == '/blog/')) %}
      {% set isNewsletter = (url and (url | slice(0, 6) == '/newsletters/')) %}
      {% set isAbout = url == '/about/' %}
      {% set isNotes = url == '/notes/' %}
      {% set isNow = url == '/now/' %}
      {% set isExplore = url == '/explore/' %}
      {% set isGuestBook = url == '/guestbook/' %}
      {% set isContact = url == '/contact/' %}
      <ul class="flex md:flex-row flex-col md:space-x-6 space-y-3 md:space-y-0 md:text-sm text-base">
        <li>
          <a href="/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isHome %}underline font-semibold{% endif %}"
            {% if isHome %}aria-current="page"{% endif %}><span aria-hidden="true">🏠</span> Home</a>
        </li>
        <li>
          <a href="/about/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isAbout %}underline font-semibold{% endif %}"
            {% if isAbout %}aria-current="page"{% endif %}><span aria-hidden="true">👋</span> Sobre</a>
        </li>
        <li>
          <a href="/now/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isNow %}underline font-semibold{% endif %}"
            {% if isNow %}aria-current="page"{% endif %}><span aria-hidden="true">📍</span> Agora</a>
        </li>
        <li>
          <a href="/blog/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isBlog %}underline font-semibold{% endif %}"
            {% if isBlog %}aria-current="page"{% endif %}><span aria-hidden="true">✍️</span> Blog
          </a>
        </li>
        <li>
          <a href="/newsletters/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isNewsletter %}underline font-semibold{% endif %}"
            {% if isNewsletter %}aria-current="page"{% endif %}><span aria-hidden="true">📥</span> Newsletter
          </a>
        </li>
        <li>
          <a href="/explore/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isExplore %}underline font-semibold{% endif %}"
            {% if isExplore %}aria-current="page"{% endif %}><span aria-hidden="true">🗺️</span> Explore</a>
        </li>
        <li>
          <a href="/guestbook/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isGuestBook %}underline font-semibold{% endif %}"
            {% if isGuestBook %}aria-current="page"{% endif %}><span aria-hidden="true">💬</span> Livro de visitas</a>
        </li>
        <li>
          <a href="/contact/" class="nav-item block py-2 text-purple-600 dark:text-purple-400 {% if isContact %}underline font-semibold{% endif %}"
            {% if isContact %}aria-current="page"{% endif %}><span aria-hidden="true">📱</span> Contato</a>
        </li>
      </ul>
    </div>
  </nav>

  <div class="flex-1 mx-auto px-4 py-6 max-w-4xl container">
    <main id="main-content">
      {{ content | safe }}
    </main>
  </div>

  {% include "partials/footer.njk" %}
</body>
</html>
