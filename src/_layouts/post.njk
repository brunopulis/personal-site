---
layout: base
schema: BlogPosting
---

<div class="wrapper region">
  <nav class="flow region" aria-label="breadcrumb">
    <ol class="cluster" role="list">
      <li><a href="/">Home</a></li>
      <li><span aria-hidden="true">›</span></li>
      <li><a href="/blog/">Blog</a></li>
      <li><span aria-hidden="true">›</span></li>
      <li>{{ title }}</li>
    </ol>
  </nav>

  <article class="h-entry flow">
    <h1 class="p-name">{{ title }}</h1>
    <p class="subtitle">{{ subtitle }}</p>

    {% if image %}
      <!-- image -->
      {%
        imageKeys {
          "src": image,
          "alt": alt or "",
          "credit": credit,
          "loading": "eager",
          "containerClass": "feature"
        }
      %}
    {% endif %}

    <div>
      Publicado em
      <time class="dt-published" datetime="{{ page.date | toISOString }}">
        {{ page.date | readableDate }}
      </time>
      • <a class="hidden u-url" href="{{ page.url }}">Link permanente</a>
    </div>

    <div class="e-content prose flow">{{ content | safe }}</div>

    {% if tags.length > 1 %}
      <!-- tags -->
      {% for tag in tags %}{% if tag != "posts" %}
        <a class="button" href="/tags/{{ tag | slugify }}/" data-small-button> {{ tag }} </a>
      {% endif %}{% endfor %}
    {% endif %}
    {% include "components/post-engagement.njk" %}
    {% include "components/newsletter.njk" %}
  </article>
</div>
