---
layout: base
title: "Filmes e Séries"
---

<a href="/watching/" class="inline-flex items-center mb-3 text-vista-blue-500 hover:text-vista-blue-600">
  <span aria-hidden="true">← </span> Filmes e Séries
</a>

<nav class="mb-4 text-sm" aria-label="Breadcrumb">
  <ol class="flex space-x-2">
    <li><a href="/" class="hover:text-blue-600">Home</a></li>
    <li><span aria-hidden="true">›</span></li>
    <li><a href="/watching/" class="hover:text-blue-600">Filmes e Séries</a></li>
    <li><span aria-hidden="true">›</span></li>
    <li class="font-bold text-gray-900">{{ title }}</li>
  </ol>
</nav>

<article class="h-entry">
  {% if poster %}
    <img
      class="mb-6 rounded-lg w-full u-photo"
      src="{{ poster | localPoster }}"
      alt="Poster de {{ title }}"
    />
  {% endif %}

  <header class="mb-6">
    <h1 class="mb-2 p-name font-bold text-3xl">{{ title }}</h1>

    {% if director %}
      <p class="mb-2 text-gray-600 text-lg">{{ director }}</p>
    {% endif %}

    <div class="flex flex-wrap items-center gap-2 mb-3">
      {% if category %}
        <span class="bg-vista-blue-100 dark:bg-vista-blue-900 p-category px-3 py-1 rounded-full text-sm">
          {{ category }}
        </span>
      {% endif %}

      {% if status %}
        <span class="bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-full text-sm">
          {{ status }}
        </span>
      {% endif %}

      {% if favorite %}
        <span class="text-yellow-500 text-sm" aria-label="Favorito">⭐ Favorito</span>
      {% endif %}
    </div>

    {% if rating %}
      <div class="flex items-center gap-1 mb-3" aria-label="Nota: {{ rating }} de 5">
        {% for i in range(1, 6) %}
          {% if i <= rating %}
            <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          {% else %}
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if watchedDate %}
      <p class="text-gray-500 text-sm">
        Assistido em
        <time class="dt-published" datetime="{{ watchedDate }}">
          {{ watchedDate | readableDate }}
        </time>
      </p>
    {% endif %}

    <a class="hidden u-url" href="{{ page.url }}">Permalink</a>
  </header>

  {% if content %}
    <div class="max-w-none e-content prose">
      {{ content | safe }}
    </div>
  {% endif %}

  <div class="flex items-center gap-4 mt-8 pt-6 border-gray-200 dark:border-gray-700 border-t">
    {% if url %}
      <a
        href="{{ url }}"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 text-vista-blue-600 hover:text-vista-blue-700 text-sm hover:underline"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        Ver no TMDB
      </a>
    {% endif %}
  </div>

</article>
