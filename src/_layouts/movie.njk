---
layout: base.njk
---
<article class="max-w-4xl mx-auto">
  <header class="mb-8">
    <div class="flex gap-6 mb-6">
      {% if poster %}
        <img
          src="{{ poster }}"
          alt="{{ title }}"
          class="w-48 h-72 object-cover rounded-lg shadow-lg"
          loading="lazy"
        >
      {% endif %}
      <div>
        <h1 class="mb-2 font-bold text-4xl">{{ title }}</h1>
        {% if director %}
          <p class="text-[var(--text-secondary)] text-lg">Dirigido por {{ director }}</p>
        {% endif %}
        {% if rating %}
          <div class="flex items-center gap-1 mt-2" aria-label="Nota: {{ rating }} de 5">
            {% for i in range(1, 6) %}
              {% if i <= rating %}
                <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              {% else %}
                <svg class="w-5 h-5 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
        {% if url %}
          <a href="{{ url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-3 text-purple-600 dark:text-purple-400 hover:underline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Ver no IMDB
          </a>
        {% endif %}
      </div>
    </div>
  </header>

  <div class="prose dark:prose-invert max-w-none">
    {{ content | safe }}
  </div>
</article>
